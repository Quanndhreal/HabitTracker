<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    xmlns:tools="http://schemas.android.com/tools"
    android:background="#FFFFFF"
    android:orientation="vertical">

    <RelativeLayout
        android:id="@+id/rlTopBar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="20dp">

        <ImageView
            android:id="@+id/ivGroup"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_alignParentStart="true"
            android:layout_centerVertical="true"
            android:background="@drawable/bg_round_stats"
            android:backgroundTint="#111111"
            android:padding="12dp"
            android:src="@android:drawable/ic_menu_myplaces"
            app:tint="#FFFFFF" />

        <TextView
            android:id="@+id/tvFeedsTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerInParent="true"
            android:text="@string/feeds"
            android:textColor="#111111"
            android:textSize="24sp"
            android:textStyle="bold|italic" />

        <ImageView
            android:id="@+id/ivBell"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_alignParentEnd="true"
            android:layout_centerVertical="true"
            android:background="@drawable/bg_round_stats"
            android:backgroundTint="#EEEEEE"
            android:padding="12dp"
            android:src="@android:drawable/ic_popup_reminder"
            app:tint="#111111" />
    </RelativeLayout>

    <LinearLayout
        android:id="@+id/llTabContainer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="20dp"
        android:background="@drawable/bg_round_stats"
        android:backgroundTint="#F5F5F5"
        android:orientation="horizontal"
        android:padding="4dp">

        <TextView
            android:id="@+id/tvTabPublic"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:background="@drawable/bg_round_stats"
            android:backgroundTint="#FFFFFF"
            android:clickable="true"
            android:elevation="2dp"
            android:focusable="true"
            android:gravity="center"
            android:text="@string/pub"
            android:textColor="#111111"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvTabFriends"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center"
            android:text="@string/friends"
            android:textColor="#888888" />

        <TextView
            android:id="@+id/tvTabMine"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center"
            android:text="@string/mine"
            android:textColor="#888888" />
    </LinearLayout>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvPosts"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:clipToPadding="false"
        android:paddingTop="16dp"
        android:paddingBottom="100dp"
        tools:listitem="@layout/item_post" />

</LinearLayout>