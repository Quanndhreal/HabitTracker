<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:paddingHorizontal="20dp"
    android:paddingBottom="24dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <ImageView
            android:id="@+id/ivAvatar"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:background="@drawable/bg_round_stats"
            android:backgroundTint="#CCCCCC"
            android:scaleType="centerCrop"
            tools:src="@tools:sample/avatars" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tvUsername"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="#111111"
                android:textStyle="bold"
                tools:text="Tên người dùng" />

            <TextView
                android:id="@+id/tvStreakInfo"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="#FF6D00"
                android:textSize="12sp"
                android:textStyle="bold"
                tools:text="Ngày 7/66" />
        </LinearLayout>

        <TextView
            android:id="@+id/tvMore"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:gravity="center"
            android:text="..."
            android:textColor="#888888"
            android:textSize="20sp"
            android:textStyle="bold" />
    </LinearLayout>

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/cvPostImage"
        android:layout_width="200dp"
        android:layout_height="280dp"
        android:layout_marginStart="60dp"
        android:layout_marginTop="12dp"
        app:cardBackgroundColor="#555555"
        app:cardCornerRadius="16dp"
        app:strokeWidth="0dp">

        <ImageView
            android:id="@+id/ivPostImage"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:scaleType="centerCrop"
            android:visibility="gone"
            tools:visibility="visible"
            tools:src="@tools:sample/backgrounds/scenic" />

        <TextView
            android:id="@+id/tvPostLocation"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="center"
            android:textColor="#DDDDDD"
            android:textSize="24sp"
            android:textStyle="bold"
            tools:text="Địa điểm" />
    </com.google.android.material.card.MaterialCardView>

    <TextView
        android:id="@+id/tvPostDescription"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="60dp"
        android:layout_marginTop="12dp"
        android:textColor="#111111"
        android:textSize="16sp"
        tools:text="Mô tả bài viết" />

    <LinearLayout
        android:id="@+id/llReactions"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginStart="60dp"
        android:layout_marginTop="12dp"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/tvReactionClap"
            android:layout_width="wrap_content"
            android:layout_height="48dp"
            android:layout_marginEnd="8dp"
            android:background="@drawable/bg_round_stats"
            android:backgroundTint="#F0F0F0"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center"
            android:minWidth="48dp"
            android:paddingHorizontal="12dp"
            android:text="👏 0" />

        <TextView
            android:id="@+id/tvReactionFire"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_marginEnd="8dp"
            android:background="@drawable/bg_round_stats"
            android:backgroundTint="#F0F0F0"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center"
            android:text="🔥" />

        <TextView
            android:id="@+id/tvReactionStrong"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_marginEnd="8dp"
            android:background="@drawable/bg_round_stats"
            android:backgroundTint="#F0F0F0"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center"
            android:text="💪" />

        <TextView
            android:id="@+id/tvReactionHeart"
            android:layout_width="wrap_content"
            android:layout_height="48dp"
            android:background="@drawable/bg_round_stats"
            android:backgroundTint="#F0F0F0"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center"
            android:minWidth="48dp"
            android:paddingHorizontal="12dp"
            android:text="❤️ 0" />
    </LinearLayout>

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:layout_marginTop="24dp"
        android:background="#EEEEEE" />

</LinearLayout>