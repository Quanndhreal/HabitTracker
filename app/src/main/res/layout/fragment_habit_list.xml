<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F9F9F9">

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingBottom="100dp">

            <LinearLayout
                android:id="@+id/llTopBar"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingHorizontal="20dp"
                android:paddingTop="20dp"
                app:layout_constraintTop_toTopOf="parent">

                <!-- Streak Badge -->
                <TextView
                    android:id="@+id/tvStreakBadge"
                    android:layout_width="wrap_content"
                    android:layout_height="48dp"
                    android:layout_marginEnd="8dp"
                    android:background="@drawable/bg_round_stats"
                    android:backgroundTint="#FF8A65"
                    android:gravity="center"
                    android:minWidth="48dp"
                    android:paddingHorizontal="12dp"
                    android:textColor="#FFFFFF"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    tools:text="🔥 0" />

                <!-- Trophy Badge -->
                <TextView
                    android:id="@+id/tvTrophyBadge"
                    android:layout_width="wrap_content"
                    android:layout_height="48dp"
                    android:layout_marginEnd="8dp"
                    android:background="@drawable/bg_round_stats"
                    android:backgroundTint="#4CAF50"
                    android:gravity="center"
                    android:minWidth="48dp"
                    android:paddingHorizontal="12dp"
                    android:textColor="#FFFFFF"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    tools:text="🏆 0" />

                <!-- XP Badge -->
                <TextView
                    android:id="@+id/tvXpBadge"
                    android:layout_width="wrap_content"
                    android:layout_height="48dp"
                    android:background="@drawable/bg_round_stats"
                    android:backgroundTint="#2196F3"
                    android:gravity="center"
                    android:minWidth="48dp"
                    android:paddingHorizontal="12dp"
                    android:textColor="#FFFFFF"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    tools:text="✦ 0" />

                <!-- Spacer -->
                <View
                    android:layout_width="0dp"
                    android:layout_height="1dp"
                    android:layout_weight="1" />

                <ImageView
                    android:id="@+id/ivSettings"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:background="@drawable/bg_round_stats"
                    android:backgroundTint="#FFFFFF"
                    android:contentDescription="Cài đặt"
                    android:padding="12dp"
                    android:src="@drawable/ic_settings"
                    app:tint="#111111" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/llDayTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="20dp"
                android:layout_marginTop="24dp"
                android:gravity="bottom"
                android:orientation="horizontal"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/llTopBar">

                <TextView
                    android:id="@+id/tvDayNumber"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="sans-serif-medium"
                    android:textColor="#111111"
                    android:textSize="42sp"
                    tools:text="Ngày 1" />

                <TextView
                    android:id="@+id/tvDayTotal"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="4dp"
                    android:fontFamily="sans-serif-medium"
                    android:textColor="#B0B0B0"
                    android:textSize="28sp"
                    tools:text="/66" />
            </LinearLayout>

            <View
                android:id="@+id/vTimelineLine"
                android:layout_width="4dp"
                android:layout_height="0dp"
                android:layout_marginStart="24dp"
                android:layout_marginTop="24dp"
                android:background="#FF8A65"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/llDayTitle" />

            <TextView
                android:id="@+id/tvSectionHeader"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:layout_marginTop="24dp"
                android:textColor="#888888"
                android:textSize="15sp"
                android:textStyle="bold"
                app:layout_constraintStart_toEndOf="@id/vTimelineLine"
                app:layout_constraintTop_toBottomOf="@id/llDayTitle"
                tools:text="Danh sách thói quen" />

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvHabits"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:nestedScrollingEnabled="false"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toEndOf="@id/vTimelineLine"
                app:layout_constraintTop_toBottomOf="@id/tvSectionHeader"
                tools:listitem="@layout/item_habit_gamified" />

        </androidx.constraintlayout.widget.ConstraintLayout>
    </androidx.core.widget.NestedScrollView>

    <com.google.android.material.floatingactionbutton.ExtendedFloatingActionButton
        android:id="@+id/fabAddHabit"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|end"
        android:layout_margin="24dp"
        android:text="Thêm thói quen"
        android:textColor="@color/white"
        app:backgroundTint="#111111"
        app:icon="@android:drawable/ic_input_add"
        app:iconTint="@color/white"
        app:shapeAppearanceOverlay="@style/ShapeAppearance.Material3.Corner.Medium" />

</androidx.coordinatorlayout.widget.CoordinatorLayout>