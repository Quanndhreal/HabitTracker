<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="#000000"
    android:padding="20dp"
    android:paddingBottom="40dp">

    <ImageView
        android:id="@+id/btnClose"
        android:layout_width="32dp"
        android:layout_height="32dp"
        android:background="@drawable/bg_round_stats"
        android:padding="8dp"
        android:src="@android:drawable/ic_menu_close_clear_cancel"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:tint="#FFFFFF" />

    <TextView
        android:id="@+id/tvStreakFreeze"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_round_stats"
        android:backgroundTint="#33FF8A65"
        android:paddingHorizontal="16dp"
        android:paddingVertical="8dp"
        android:text="Đóng băng chuỗi 🧊"
        android:textColor="#FF8A65"
        android:textStyle="bold"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:id="@+id/tvBigStreak"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:text="0"
        android:textColor="#FFFFFF"
        android:textSize="80sp"
        android:textStyle="bold"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/btnClose" />

    <TextView
        android:id="@+id/tvStreakSubtitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="ngày liên tiếp"
        android:textColor="#FFFFFF"
        android:textSize="28sp"
        android:textStyle="bold"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tvBigStreak" />

    <!-- Challenge Card -->
    <LinearLayout
        android:id="@+id/llChallengeCard"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="32dp"
        android:background="@drawable/bg_round_stats"
        android:backgroundTint="#1A1A1A"
        android:orientation="vertical"
        android:padding="16dp"
        app:layout_constraintTop_toBottomOf="@id/tvStreakSubtitle">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Thử thách 7 ngày"
                android:textColor="#FFFFFF"
                android:textSize="16sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvChallengeDay"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Ngày 1/7"
                android:textColor="#888888" />
        </LinearLayout>

        <!-- Challenge Days -->
        <LinearLayout
            android:id="@+id/llChallengeDays"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:orientation="horizontal" />
    </LinearLayout>

    <TextView
        android:id="@+id/tvGuide"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="32dp"
        android:text="Để duy trì chuỗi, hãy hoàn thành ít nhất 2\nnhiệm vụ trong một ngày."
        android:textAlignment="center"
        android:textColor="#CCCCCC"
        app:layout_constraintTop_toBottomOf="@id/llChallengeCard" />

    <!-- Achievements Grid -->
    <GridLayout
        android:id="@+id/glAchievements"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:alignmentMode="alignMargins"
        android:columnCount="2"
        app:layout_constraintTop_toBottomOf="@id/tvGuide" />

</androidx.constraintlayout.widget.ConstraintLayout>